<%# ── Filtros ── %>
<div class="mb-5">
    <form hx-get="/<%= entidade.http_path_name %>"
          hx-target="main"
          hx-swap="innerHTML"
          hx-trigger="change, keyup delay:500ms"
          class="flex flex-wrap gap-2">

          <% colunasVisiveis.forEach(coluna => { %>

          <% if (coluna.tipo === 'boolean') { %>
          <label class="flex items-center gap-1 text-sm border border-gray-300 rounded px-2 py-1 bg-white">
              <input type="checkbox" name="filtro_<%= coluna.nome %>" class="h-4 w-4">
              <%= coluna.label ?? coluna.nome %>
          </label>

          <% } else if (coluna.tipo === 'search') { %>
          <div class="relative" data-search-field>
              <input
                      type="text"
                      hx-post="/<%= entidade.http_path_name %>/search?coluna=<%= coluna.nome %>"
                      hx-trigger="keyup changed delay:500ms"
                      hx-target="next ul"
                      hx-params="busca"
                      hx-vals='js:{ "busca": document.activeElement.value }'
                      hx-swap="innerHTML"
                      placeholder="<%= coluna.label ?? coluna.nome %>..."
                      class="p-2 border border-gray-300 rounded text-sm"
                      autocomplete="off"
                      data-search-input>
                      <ul class="hidden absolute z-10 w-full bg-white border border-gray-300 rounded shadow-sm mt-1 max-h-48 overflow-y-auto" data-search-dropdown></ul>
                      <input type="hidden" name="filtro_<%= coluna.nome %>_id" data-search-hidden>
          </div>

          <% } else if (coluna.tipo !== 'label' && !coluna.pk) { %>
          <input
                  type="<%= coluna.tipo === 'number' ? 'number' : 'text' %>"
                  name="filtro_<%= coluna.nome %>"
                  placeholder="<%= coluna.label ?? coluna.nome %>..."
                  class="p-2 border border-gray-300 rounded text-sm">

                  <% } %>

                  <% }) %>

                  <button type="submit" class="px-4 py-2 bg-gray-100 border border-gray-300 rounded text-sm hover:bg-gray-200">Filtrar</button>
                  <button type="reset" hx-get="/<%= entidade.http_path_name %>" hx-target="main" hx-swap="innerHTML" class="px-4 py-2 bg-gray-100 border border-gray-300 rounded text-sm hover:bg-gray-200">Limpar</button>
    </form>
</div>
